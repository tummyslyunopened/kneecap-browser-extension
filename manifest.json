{
  "manifest_version": 3,
  "name": "Better Subscriptions for YouTube™",
  "short_name": "Better Subs",

  "version": "0.19.2",
  "description": "Make navigating YouTube's subscription grid easier by hiding watched videos",
  "icons": {
    "48": "icons/ic_video_library_black_48dp_1x.png"
  },
  "action": {
    "default_icon": {
      "48": "icons/ic_video_library_black_48dp_1x.png"
    }
  },
  "developer": {
    "name": "Oscar Hernandez",
    "url": "https://github.com/OsaSoft"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.youtube.com/*"
  ],
  "background": {
    "service_worker": "pages/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "util.js",
        "common.js",
        "settingsLoader.js",
        "queries.js",
        "videos/Video.js",
        "videos/SubscriptionsVideo.js",
        "subs-ui.js",
        "subs.js",
        "vid.js",
        "pageHandler.js",
        "tweaks.js"
      ],
      "css": [
        "common.css",
        "subs.css"

      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["images/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "options_ui": {
    "page": "pages/settings/settings.html",
    "open_in_tab": true
  }
}

